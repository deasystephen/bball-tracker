{
  "name": "bball-tracker-backend",
  "version": "0.1.0",
  "description": "Basketball Tracker Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:seed": "npx prisma db seed",
    "db:reset": "tsx prisma/reset.ts",
    "db:fresh": "tsx prisma/reset.ts && npx prisma db seed"
  },
  "keywords": [
    "basketball",
    "tracker",
    "api"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1093.0",
    "@aws-sdk/client-sesv2": "^3.1093.0",
    "@aws-sdk/s3-request-presigner": "^3.1093.0",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@sentry/node": "^10.66.0",
    "@workos-inc/node": "^8.13.0",
    "cors": "^2.8.5",
    "csv-stringify": "^6.8.1",
    "dotenv": "^17.4.2",
    "expo-server-sdk": "^6.1.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "ics": "^3.12.0",
    "ioredis": "^5.11.1",
    "kafkajs": "^2.2.4",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "prisma": "^7.9.0",
    "socket.io": "^4.6.1",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "minimatch": "^3.1.3",
    "@hono/node-server": "^1.19.13",
    "fast-uri": "^3.1.2",
    "fast-xml-builder": "^1.2.0",
    "form-data": "^4.0.6",
    "hono": "^4.12.25",
    "undici": "^7.28.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^25.9.5",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.3",
    "ts-jest": "^29.4.12",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0"
  }
}
